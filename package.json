{
  "name": "service_request_management_system",
  "version": "1.0.0",
  "private": true,

  "dependencies": {
    "@sap/cds": "^9",
    "@cap-js/hana": "^2",
    "@sap/xssec": "^4"
  },

  "devDependencies": {
    "@sap/cds-dk": "^9",
    "@cap-js/sqlite": "^2",
    "cds-plugin-ui5": "^0.13.0"
  },

  "scripts": {
    "start": "cds-serve",
    "watch-project1": "cds watch --open project1/index.html?sap-ui-xx-viewCache=false --livereload false"
  },

  "workspaces": [
    "app/*"
  ],

  "cds": {
    "requires": {
      "db": {
        "kind": "hana"
      },

      "[development]": {
        "db": {
          "kind": "sqlite"
        },
        "auth": {
          "kind": "mocked"
        }
      },

      "[production]": {
        "db": {
          "kind": "hana"
        },
        "auth": {
          "kind": "xsuaa"
        }
      },

      "destinations": true,
      "html5-repo": true,
      "workzone": true
    }
  },

  "sapux": [
    "app/project1"
  ]
}